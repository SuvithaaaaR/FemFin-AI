# Production Environment Variables for Server

# Server Configuration
PORT=5000
NODE_ENV=production

# Client URL (your production domain)
CLIENT_URL=https://your-domain.com

# MongoDB Connection (REQUIRED for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/femfin-ai?retryWrites=true&w=majority

# JWT Secret (MUST be strong and unique!)
JWT_SECRET=your_super_secure_random_jwt_secret_change_this_please
JWT_EXPIRE=24h

# API Keys
# OpenAI API Key (for AI recommendations)
OPENAI_API_KEY=your_openai_api_key_here

# Blockchain API Keys
INFURA_PROJECT_ID=your_infura_project_id
BLOCKCHAIN_API_KEY=your_blockchain_api_key
ETHEREUM_NETWORK=mainnet

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Security
CORS_ORIGIN=https://your-domain.com
ENABLE_RATE_LIMIT=true
